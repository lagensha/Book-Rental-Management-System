<AnchorPane prefHeight="400.0" prefWidth="600.0" style="-fx-background-color: #810B38;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="edu.icet.ecom.controller.UserController">
   <children>
      <Label layoutX="199.0" layoutY="23.0" text="User Records" textFill="#f2f0f0">
         <font>
            <Font name="System Bold" size="25.0" />
         </font>
      </Label>
      <TextField fx:id="txtId" layoutX="84.0" layoutY="81.0" promptText="UserId" />
      <TextField fx:id="txtName" layoutX="353.0" layoutY="81.0" promptText="Name" />
      <TextField fx:id="txtEmail" layoutX="84.0" layoutY="126.0" promptText="Email" />
      <TextField fx:id="txtPhoneNumber" layoutX="353.0" layoutY="126.0" promptText="PhoneNumber" />
      <Button fx:id="btnCreate" layoutX="42.0" layoutY="175.0" mnemonicParsing="false" onAction="#btnCreateOnAction" prefHeight="25.0" prefWidth="84.0" text="Create" />
      <Button fx:id="btnReset" layoutX="338.0" layoutY="175.0" mnemonicParsing="false" onAction="#btnResetOnAction" prefHeight="25.0" prefWidth="84.0" text="Reset" />
