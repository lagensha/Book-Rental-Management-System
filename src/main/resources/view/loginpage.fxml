<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" style="-fx-background-color: #412D15;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="edu.icet.ecom.controller.LoginPageController">
   <children>
      <Label layoutX="228.0" layoutY="25.0" prefHeight="32.0" prefWidth="102.0" text="Login Page" textFill="WHITE">
         <font>
            <Font size="20.0" />
         </font>
      </Label>
      <Label layoutX="56.0" layoutY="84.0" prefHeight="32.0" prefWidth="102.0" text="User Name :" textFill="WHITE">
         <font>
            <Font size="17.0" />
         </font>
      </Label>
      <ComboBox fx:id="cmbRole" accessibleText="Staff" layoutX="138.0" layoutY="259.0" prefWidth="150.0" promptText="Admin" />
      <Button fx:id="btnLogin" layoutX="253.0" layoutY="311.0" mnemonicParsing="false" onAction="#btnLoginOnAction" prefHeight="25.0" prefWidth="76.0" text="Login">
         <font>
            <Font name="System Bold" size="12.0" />
         </font>
      </Button>
      <Label layoutX="50.0" layoutY="141.0" prefHeight="32.0" prefWidth="102.0" text="Password  :" textFill="WHITE">
         <font>
            <Font size="17.0" />
         </font>
      </Label>
      <Label layoutX="50.0" layoutY="200.0" prefHeight="32.0" prefWidth="102.0" text="Email   :" textFill="WHITE">
         <font>
            <Font size="17.0" />
         </font>
      </Label>
      <TextField fx:id="txtUserName" layoutX="204.0" layoutY="88.0" prefHeight="25.0" prefWidth="202.0" />
      <TextField fx:id="txtPassword" layoutX="204.0" layoutY="145.0" prefHeight="25.0" prefWidth="202.0" promptText="******" />
      <TextField layoutX="204.0" layoutY="204.0" prefHeight="25.0" prefWidth="238.0" promptText=" @gmail.com" />
   </children>
</AnchorPane>
